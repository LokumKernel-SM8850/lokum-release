### AnyKernel3 Ramdisk Mod Script
## LokumKernel for Xiaomi SM8850 / Xiaomi 17 series
## Based on osm0sis AnyKernel3 template

properties() { '
kernel.string=Lokum Kernel Xiaomi 17 series by MetoisTaken
do.devicecheck=1
do.modules=0
do.systemless=1
do.cleanup=1
do.cleanuponabort=0
device.name1=pudding
device.name2=pandora
device.name3=popsicle
device.name4=nezha
device.name5=
supported.versions=16
supported.patchlevels=
supported.vendorpatchlevels=
'; }

BLOCK=boot;
IS_SLOT_DEVICE=auto;
RAMDISK_COMPRESSION=auto;
PATCH_VBMETA_FLAG=auto;

. tools/ak3-core.sh;

split_boot;
flash_boot;
