### AnyKernel3 Ramdisk Mod Script
## LokumKernel for Xiaomi pandora
## Based on osm0sis AnyKernel3 template

properties() { '
kernel.string=LokumKernel 6.12.23-android16-5 for Xiaomi pandora by meto
do.devicecheck=1
do.modules=0
do.systemless=1
do.cleanup=1
do.cleanuponabort=0
device.name1=pandora
device.name2=
device.name3=
device.name4=
device.name5=
supported.versions=16
supported.patchlevels=
supported.vendorpatchlevels=
'; }

BLOCK=boot;
IS_SLOT_DEVICE=auto;
RAMDISK_COMPRESSION=auto;
PATCH_VBMETA_FLAG=auto;

. tools/ak3-core.sh;

split_boot;
flash_boot;
